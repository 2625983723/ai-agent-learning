# ============================================
# AI Agent 学习工程 - Git 忽略规则
# 这些文件不需要上传到 GitHub
# ============================================

# ---- Python 虚拟环境 ----
.venv/
venv/
env/
ENV/

# ---- Python 编译产物 ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ---- 分发/打包 ----
*.egg-info/
dist/
build/
*.egg

# ---- 测试覆盖率 ----
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
*.cover
.pytest_cache/

# ---- Jupyter Notebook 检查点 ----
.ipynb_checkpoints/

# ---- 环境变量文件（包含敏感信息）----
.env
.env.local
.env.*.local

# ---- IDE / 编辑器配置 ----
.idea/
.vscode/
*.swp
*.swo
*~

# ---- 操作系统文件 ----
.DS_Store
Thumbs.db
desktop.ini

# ---- ChromaDB 向量数据库（体积大）----
chroma_db/
chroma_data/
*.db
*.sqlite3

# ---- 日志文件 ----
logs/
*.log

# ---- 临时文件 ----
tmp/
temp/
tmp_*
